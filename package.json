{
  "name": "@kaalveniiz/gmlp-auditor",
  "version": "0.1.0",
  "description": "GMLP-aligned compliance auditor for medical LLM outputs (candidate model + judge model).",
  "license": "CC0-1.0",
  "private": false,
  "bin": {
    "gmlp-auditor": "./cli/gmlp-auditor.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "cli/",
    "judges/",
    "prompts/",
    "data/",
    "agent/",
    "README.md",
    "README.zh-CN.md",
    "LICENCE",
    "PUBLISHING.md",
    "NPM_PUBLISHING.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "gmlp-auditor": "node ./cli/gmlp-auditor.js",
    "eval:module3": "node ./cli/gmlp-auditor.js eval --module 3"
  },
  "dependencies": {}
}
